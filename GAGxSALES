<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GAGxSALES — Grow a Garden 2</title>
  <style>
    :root{
      --bg:#070707;
      --bg2:#0d0d0d;
      --card:#131313;
      --card2:#1a1a1a;
      --gold:#d4af37;
      --gold2:#f5d76e;
      --gold3:#9c7a16;
      --text:#ffffff;
      --muted:#b7b7b7;
      --line:rgba(212,175,55,.18);
      --danger:#ff5c5c;
      --success:#63d98f;
      --radius:22px;
      --shadow:0 20px 50px rgba(0,0,0,.35);
      --transition:.25s ease;
    }

    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      font-family:Arial,Helvetica,sans-serif;
      background:
        radial-gradient(circle at top right, rgba(212,175,55,.12), transparent 28%),
        radial-gradient(circle at top left, rgba(212,175,55,.08), transparent 22%),
        linear-gradient(180deg,var(--bg),var(--bg2));
      color:var(--text);
      overflow-x:hidden;
    }

    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}
    button,input{font-family:inherit}

    .container{
      width:min(1200px,92%);
      margin:0 auto;
    }

    .hidden{display:none !important;}

    /* HEADER */
    header{
      position:sticky;
      top:0;
      z-index:1000;
      backdrop-filter:blur(12px);
      background:rgba(8,8,8,.88);
      border-bottom:1px solid var(--line);
    }

    .nav{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:20px;
      padding:18px 0;
      flex-wrap:wrap;
    }

    .logo{
      display:flex;
      align-items:center;
      gap:12px;
      font-size:1.35rem;
      font-weight:900;
      letter-spacing:1px;
      color:var(--gold);
    }

    .logo-badge{
      width:14px;
      height:14px;
      border-radius:50%;
      background:radial-gradient(circle at 30% 30%, #fff6cb, var(--gold));
      box-shadow:0 0 20px rgba(212,175,55,.45);
    }

    .nav-right{
      display:flex;
      align-items:center;
      gap:14px;
      flex-wrap:wrap;
    }

    .nav-links{
      display:flex;
      gap:18px;
      flex-wrap:wrap;
      align-items:center;
    }

    .nav-links a{
      font-weight:700;
      transition:var(--transition);
    }

    .nav-links a:hover{
      color:var(--gold2);
    }

    .btn{
      border:none;
      cursor:pointer;
      border-radius:16px;
      padding:14px 20px;
      font-weight:800;
      transition:var(--transition);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
    }

    .btn:hover{transform:translateY(-2px)}

    .btn-primary{
      background:linear-gradient(135deg,var(--gold),var(--gold3));
      color:#111;
      box-shadow:0 12px 30px rgba(212,175,55,.18);
    }

    .btn-secondary{
      background:transparent;
      color:var(--gold2);
      border:1px solid rgba(212,175,55,.25);
    }

    .btn-danger{
      background:#1a1a1a;
      border:1px solid rgba(255,92,92,.25);
      color:#ffb1b1;
    }

    .btn.full{width:100%}
    .btn.small{padding:10px 14px;font-size:.92rem}

    .cart-pill{
      display:flex;
      align-items:center;
      gap:10px;
      border-radius:999px;
      padding:10px 14px;
      background:rgba(255,255,255,.03);
      border:1px solid var(--line);
      color:var(--gold2);
      font-weight:800;
      cursor:pointer;
    }

    .cart-pill span{
      min-width:28px;
      height:28px;
      border-radius:999px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:linear-gradient(135deg,var(--gold),var(--gold3));
      color:#111;
      font-weight:900;
    }

    /* HERO */
    .hero{
      min-height:90vh;
      display:flex;
      align-items:center;
      position:relative;
      overflow:hidden;
    }

    .hero::before{
      content:"";
      position:absolute;
      right:-140px;
      top:-140px;
      width:520px;
      height:520px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(212,175,55,.16), transparent 68%);
      filter:blur(8px);
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1.1fr .9fr;
      gap:34px;
      align-items:center;
      padding:70px 0;
      position:relative;
      z-index:1;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:8px 14px;
      border-radius:999px;
      border:1px solid var(--line);
      background:rgba(212,175,55,.06);
      color:var(--gold2);
      font-weight:800;
      text-transform:uppercase;
      font-size:.88rem;
      letter-spacing:.8px;
      margin-bottom:18px;
    }

    .live-dot{
      width:8px;
      height:8px;
      border-radius:50%;
      background:var(--gold);
      box-shadow:0 0 12px rgba(212,175,55,.5);
    }

    .hero h1{
      font-size:clamp(2.8rem,6vw,5rem);
      line-height:1.02;
      margin-bottom:18px;
    }

    .hero h1 span{color:var(--gold)}

    .hero p{
      color:var(--muted);
      font-size:1.05rem;
      max-width:720px;
      line-height:1.7;
      margin-bottom:28px;
    }

    .hero-actions{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      margin-bottom:34px;
    }

    .hero-stats{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:16px;
    }

    .stat-card,.panel,.product-card,.featured-card{
      background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }

    .stat-card{
      padding:18px;
    }

    .stat-card h3{
      color:var(--gold);
      margin-bottom:8px;
      font-size:1.08rem;
    }

    .stat-card p{
      color:var(--muted);
      font-size:.95rem;
      line-height:1.55;
    }

    .featured-card{overflow:hidden}

    .featured-image,.product-image{
      min-height:320px;
      display:flex;
      align-items:center;
      justify-content:center;
      position:relative;
      padding:28px;
      background:
        radial-gradient(circle at center, rgba(255,90,40,.42), rgba(255,70,20,.14) 42%, transparent 72%),
        linear-gradient(180deg,#181818,#101010);
    }

    .featured-image img,.product-image img{
      width:220px;
      object-fit:contain;
      filter:drop-shadow(0 20px 30px rgba(255,90,0,.28));
    }

    .stock-badge{
      position:absolute;
      top:16px;
      right:16px;
      background:linear-gradient(135deg,var(--gold),var(--gold3));
      color:#111;
      font-weight:900;
      font-size:.82rem;
      border-radius:999px;
      padding:8px 12px;
    }

    .featured-body,.product-body{
      padding:24px;
    }

    .product-label{
      color:var(--gold2);
      text-transform:uppercase;
      letter-spacing:1.1px;
      font-size:.78rem;
      font-weight:800;
    }

    .featured-body h3,.product-body h3{
      font-size:1.6rem;
      margin:10px 0;
    }

    .featured-body p,.product-body p{
      color:var(--muted);
      line-height:1.65;
    }

    .featured-footer{
      margin-top:18px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      flex-wrap:wrap;
    }

    .featured-price,.product-price{
      font-size:1.6rem;
      font-weight:900;
      color:var(--gold);
    }

    /* SECTIONS */
    section{padding:92px 0}

    .section-head{
      margin-bottom:28px;
    }

    .section-head h2{
      font-size:clamp(2rem,4vw,2.8rem);
      margin-bottom:10px;
    }

    .section-head h2 span{color:var(--gold)}
    .section-head p{color:var(--muted)}

    /* SHOP */
    .shop-single{
      display:grid;
      grid-template-columns:minmax(320px,720px);
      justify-content:center;
    }

    .product-meta{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      margin:20px 0;
      flex-wrap:wrap;
    }

    .qty-box{
      display:flex;
      align-items:center;
      gap:14px;
      background:#111;
      border:1px solid var(--line);
      border-radius:16px;
      padding:12px 14px;
      min-width:120px;
      justify-content:space-between;
    }

    .qty-btn{
      border:none;
      background:transparent;
      color:#fff;
      cursor:pointer;
      font-size:1.15rem;
      width:28px;
      height:28px;
    }

    .qty-value{font-weight:800}

    /* ORDER + CHAT */
    .order-layout,.contact-grid{
      display:grid;
      grid-template-columns:1.05fr .95fr;
      gap:24px;
    }

    .panel{padding:24px}

    .panel-head{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      margin-bottom:20px;
      flex-wrap:wrap;
    }

    .panel-head h3,.contact-panel h3{
      color:var(--gold);
      font-size:1.3rem;
    }

    .order-empty,.chat-locked,.empty-state{
      border:1px dashed rgba(212,175,55,.22);
      border-radius:18px;
      padding:22px;
      background:rgba(212,175,55,.03);
      color:var(--muted);
      line-height:1.6;
    }

    .order-card{
      display:grid;
      gap:16px;
    }

    .order-top{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:18px;
      flex-wrap:wrap;
    }

    .order-id{
      color:var(--gold);
      font-size:1.2rem;
      font-weight:900;
    }

    .order-sub{
      color:var(--muted);
      font-size:.95rem;
      margin-top:4px;
    }

    .status-badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:10px 14px;
      border-radius:999px;
      font-weight:900;
      font-size:.9rem;
      white-space:nowrap;
    }

    .status-waiting{
      background:rgba(212,175,55,.12);
      color:var(--gold2);
      border:1px solid rgba(212,175,55,.26);
    }

    .order-grid{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:14px;
    }

    .order-info-box{
      background:rgba(255,255,255,.02);
      border:1px solid rgba(212,175,55,.12);
      border-radius:18px;
      padding:16px;
    }

    .order-info-box h4{
      color:var(--gold2);
      margin-bottom:6px;
      font-size:.95rem;
    }

    .order-info-box p{
      color:#fff;
      font-weight:700;
      line-height:1.5;
    }

    .order-product{
      display:grid;
      grid-template-columns:80px 1fr;
      gap:16px;
      align-items:center;
      background:rgba(255,255,255,.02);
      border:1px solid rgba(212,175,55,.12);
      border-radius:20px;
      padding:16px;
    }

    .order-product-thumb,.cart-thumb{
      width:80px;
      height:80px;
      border-radius:18px;
      background:
        radial-gradient(circle at center, rgba(255,90,40,.42), rgba(255,70,20,.14) 42%, transparent 72%),
        linear-gradient(180deg,#181818,#101010);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:10px;
    }

    .order-product-thumb img,.cart-thumb img{
      width:54px;
      object-fit:contain;
    }

    .chat-app{
      display:flex;
      flex-direction:column;
      gap:16px;
    }

    .chat-messages{
      height:420px;
      overflow:auto;
      display:flex;
      flex-direction:column;
      gap:12px;
      padding:10px;
      background:rgba(255,255,255,.02);
      border:1px solid rgba(212,175,55,.1);
      border-radius:20px;
    }

    .chat-message{
      max-width:82%;
      padding:12px 14px;
      border-radius:16px;
      line-height:1.45;
    }

    .chat-message.customer{
      align-self:flex-end;
      background:linear-gradient(135deg,var(--gold),var(--gold3));
      color:#111;
      font-weight:700;
    }

    .chat-message.system{
      align-self:flex-start;
      background:#161616;
      border:1px solid rgba(212,175,55,.1);
      color:#fff;
    }

    .chat-meta{
      font-size:.78rem;
      opacity:.8;
      margin-top:6px;
    }

    .chat-input-row{
      display:grid;
      grid-template-columns:1fr auto;
      gap:12px;
    }

    .chat-input-row input,.checkout-form input{
      background:#111;
      border:1px solid var(--line);
      color:#fff;
      border-radius:16px;
      padding:14px 16px;
      outline:none;
    }

    /* CONTACT */
    .contact-item,.info-item{
      background:rgba(255,255,255,.02);
      border:1px solid rgba(212,175,55,.12);
      border-radius:18px;
      padding:16px;
      margin-bottom:14px;
    }

    .contact-item h4{
      color:var(--gold2);
      margin-bottom:6px;
    }

    .contact-item p,.contact-item a{
      color:var(--muted);
      word-break:break-word;
    }

    .contact-actions{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      margin-top:20px;
    }

    .info-list{
      display:grid;
      gap:12px;
    }

    .info-item{
      display:flex;
      gap:12px;
      align-items:flex-start;
      color:var(--muted);
      line-height:1.6;
    }

    .info-item strong{color:var(--gold)}

    /* CART */
    .cart-overlay,.modal-overlay{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.58);
      opacity:0;
      visibility:hidden;
      transition:var(--transition);
      z-index:1200;
    }

    .cart-overlay.show,.modal-overlay.show{
      opacity:1;
      visibility:visible;
    }

    .cart-sidebar{
      position:fixed;
      top:0;
      right:0;
      width:min(430px,100%);
      height:100vh;
      background:linear-gradient(180deg,#111,#0c0c0c);
      border-left:1px solid var(--line);
      z-index:1300;
      transform:translateX(100%);
      transition:var(--transition);
      display:flex;
      flex-direction:column;
      box-shadow:-12px 0 40px rgba(0,0,0,.35);
    }

    .cart-sidebar.show{transform:translateX(0)}

    .cart-header{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      padding:20px;
      border-bottom:1px solid var(--line);
    }

    .cart-header h3{color:var(--gold)}

    .icon-btn{
      width:42px;
      height:42px;
      border-radius:14px;
      border:1px solid var(--line);
      background:transparent;
      color:#fff;
      cursor:pointer;
      transition:var(--transition);
    }

    .icon-btn:hover{
      background:rgba(212,175,55,.06);
      color:var(--gold2);
    }

    .cart-items{
      flex:1;
      overflow:auto;
      padding:20px;
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .cart-item{
      display:grid;
      grid-template-columns:72px 1fr auto;
      gap:14px;
      align-items:center;
      background:rgba(255,255,255,.02);
      border:1px solid rgba(212,175,55,.10);
      border-radius:18px;
      padding:14px;
    }

    .cart-thumb{
      width:72px;
      height:72px;
    }

    .cart-thumb img{width:46px}

    .cart-info h4{margin-bottom:4px}
    .cart-info p{
      color:var(--muted);
      font-size:.92rem;
      margin-bottom:8px;
    }

    .cart-controls{
      display:flex;
      gap:8px;
      align-items:center;
      flex-wrap:wrap;
    }

    .mini-btn{
      width:30px;
      height:30px;
      border-radius:10px;
      border:1px solid var(--line);
      background:#111;
      color:#fff;
      cursor:pointer;
    }

    .remove-btn{
      border:none;
      background:transparent;
      color:var(--danger);
      cursor:pointer;
      font-weight:700;
    }

    .cart-price{
      color:var(--gold);
      font-weight:900;
      white-space:nowrap;
    }

    .cart-footer{
      border-top:1px solid var(--line);
      padding:20px;
      display:grid;
      gap:14px;
    }

    .cart-summary-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .cart-summary-row strong{
      color:var(--gold);
      font-size:1.2rem;
    }

    .small-note{
      color:var(--muted);
      font-size:.93rem;
      line-height:1.6;
    }

    /* CHECKOUT */
    .checkout-modal{
      position:fixed;
      top:50%;
      left:50%;
      transform:translate(-50%,-50%) scale(.96);
      width:min(920px,94%);
      background:linear-gradient(180deg,#121212,#0d0d0d);
      border:1px solid var(--line);
      border-radius:28px;
      z-index:1400;
      box-shadow:0 30px 60px rgba(0,0,0,.45);
      opacity:0;
      visibility:hidden;
      transition:var(--transition);
    }

    .checkout-modal.show{
      opacity:1;
      visibility:visible;
      transform:translate(-50%,-50%) scale(1);
    }

    .checkout-header{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:14px;
      padding:22px 24px;
      border-bottom:1px solid var(--line);
    }

    .checkout-header h3{
      color:var(--gold);
      font-size:1.4rem;
    }

    .checkout-body{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:22px;
      padding:24px;
    }

    .checkout-form,.checkout-summary{
      background:rgba(255,255,255,.02);
      border:1px solid rgba(212,175,55,.10);
      border-radius:22px;
      padding:22px;
    }

    .checkout-form h4,.checkout-summary h4{
      color:var(--gold);
      margin-bottom:16px;
    }

    .checkout-form label{
      display:block;
      margin-bottom:8px;
      color:var(--gold2);
      font-size:.95rem;
      font-weight:700;
    }

    .checkout-form input{
      width:100%;
      margin-bottom:16px;
    }

    .summary-box{
      display:grid;
      gap:14px;
    }

    .summary-line{
      display:flex;
      justify-content:space-between;
      gap:16px;
      color:var(--muted);
    }

    .summary-line strong{color:#fff}

    .summary-total{
      display:flex;
      justify-content:space-between;
      gap:16px;
      padding-top:14px;
      border-top:1px solid var(--line);
      font-size:1.1rem;
    }

    .summary-total strong{color:var(--gold)}

    /* TOAST */
    .toast{
      position:fixed;
      right:20px;
      bottom:20px;
      z-index:2000;
      min-width:280px;
      max-width:92vw;
      background:#101010;
      border:1px solid rgba(212,175,55,.3);
      color:#fff;
      border-radius:18px;
      padding:16px 18px;
      box-shadow:var(--shadow);
      transform:translateY(20px);
      opacity:0;
      pointer-events:none;
      transition:.3s ease;
    }

    .toast.show{
      transform:translateY(0);
      opacity:1;
    }

    .toast strong{
      color:var(--gold);
      display:block;
      margin-bottom:4px;
    }

    .toast p{
      color:var(--muted);
      font-size:.95rem;
    }

    footer{
      padding:30px 0 42px;
      border-top:1px solid var(--line);
      text-align:center;
      color:var(--muted);
      background:rgba(0,0,0,.16);
    }

    footer span{
      color:var(--gold);
      font-weight:800;
    }

    /* RESPONSIVE */
    @media (max-width:1100px){
      .hero-grid,
      .order-layout,
      .contact-grid,
      .checkout-body{
        grid-template-columns:1fr;
      }
      .hero{min-height:auto}
      .hero-stats{grid-template-columns:1fr}
    }

    @media (max-width:760px){
      .nav{
        flex-direction:column;
        align-items:flex-start;
      }

      .nav-right{
        width:100%;
        justify-content:space-between;
      }

      .nav-links{gap:14px}
      .featured-footer,.product-meta,.contact-actions{
        flex-direction:column;
        align-items:flex-start;
      }

      .order-grid{grid-template-columns:1fr}
      .chat-input-row{grid-template-columns:1fr}
      .cart-sidebar{width:100%}
    }
  </style>
</head>
<body>

  <!-- TOAST -->
  <div class="toast" id="toast">
    <strong>Succes</strong>
    <p id="toastText">Actie voltooid.</p>
  </div>

  <!-- CHECKOUT OVERLAY -->
  <div class="modal-overlay" id="checkoutOverlay"></div>

  <!-- CHECKOUT MODAL -->
  <div class="checkout-modal" id="checkoutModal">
    <div class="checkout-header">
      <h3>Checkout</h3>
      <button id="closeCheckout" class="icon-btn">✕</button>
    </div>

    <div class="checkout-body">
      <div class="checkout-form">
        <h4>Klantgegevens</h4>

        <label>Roblox username</label>
        <input type="text" id="robloxUsername" placeholder="Bijv. MyRobloxUser123" />

        <label>Voornaam</label>
        <input type="text" id="firstName" placeholder="Je voornaam" />

        <label>Achternaam</label>
        <input type="text" id="lastName" placeholder="Je achternaam" />

