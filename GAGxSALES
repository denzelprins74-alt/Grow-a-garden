  <script>
    const TIKKIE_URL = "https://tikkie.me/pay/u87eq681egq8c9l0m25l";
    const STORAGE_CART_KEY = "gagxsales_cart_v4";
    const STORAGE_ORDERS_KEY = "gagxsales_orders_v4";
    const STORAGE_LAST_ORDER_KEY = "gagxsales_last_order_v4";

    const cartSidebar = document.getElementById("cartSidebar");
    const cartOverlay = document.getElementById("cartOverlay");
    const cartOpenBtn = document.getElementById("cartOpenBtn");
    const cartClose = document.getElementById("cartClose");
    const cartItemsEl = document.getElementById("cartItems");
    const cartTotalEl = document.getElementById("cartTotal");
    const cartCountEl = document.getElementById("cartCount");

    const checkoutBtn = document.getElementById("checkoutBtn");
    const checkoutOverlay = document.getElementById("checkoutOverlay");
    const checkoutModal = document.getElementById("checkoutModal");
    const closeCheckout = document.getElementById("closeCheckout");
    const confirmCheckoutBtn = document.getElementById("confirmCheckoutBtn");
    const checkoutSummaryBox = document.getElementById("checkoutSummaryBox");

    const robloxUsernameInput = document.getElementById("robloxUsername");
    const firstNameInput = document.getElementById("firstName");
    const lastNameInput = document.getElementById("lastName");

    const toast = document.getElementById("toast");
    const toastText = document.getElementById("toastText");

    const orderContent = document.getElementById("orderContent");
    const loadLatestOrderBtn = document.getElementById("loadLatestOrderBtn");

    const chatLockedState = document.getElementById("chatLockedState");
    const chatApp = document.getElementById("chatApp");
    const chatMessages = document.getElementById("chatMessages");
    const chatInput = document.getElementById("chatInput");
    const sendChatBtn = document.getElementById("sendChatBtn");

    let cart = loadCart();
    let activeOrder = null;

    function showToast(message){
      toastText.textContent = message;
      toast.classList.add("show");
      clearTimeout(showToast._timer);
      showToast._timer = setTimeout(() => {
        toast.classList.remove("show");
      }, 2500);
    }

    function formatPrice(value){
      return "€ " + Number(value).toFixed(2).replace(".", ",");
    }

    function formatDate(dateString){
      return new Date(dateString).toLocaleString("nl-NL");
    }

    function generateOrderId(){
      return "GAG-" + Math.floor(10000 + Math.random() * 90000);
    }

    function getChatStorageKey(orderId){
      return "gagxsales_chat_" + orderId;
    }

    function saveCart(){
      localStorage.setItem(STORAGE_CART_KEY, JSON.stringify(cart));
    }

    function loadCart(){
      const raw = localStorage.getItem(STORAGE_CART_KEY);
      return raw ? JSON.parse(raw) : {};
    }

    function loadOrders(){
      const raw = localStorage.getItem(STORAGE_ORDERS_KEY);
      return raw ? JSON.parse(raw) : [];
    }

    function saveOrders(orders){
      localStorage.setItem(STORAGE_ORDERS_KEY, JSON.stringify(orders));
    }

    function saveLastOrderId(orderId){
      localStorage.setItem(STORAGE_LAST_ORDER_KEY, orderId);
    }

    function loadLastOrderId(){
      return localStorage.getItem(STORAGE_LAST_ORDER_KEY);
    }

    function getTotalCount(){
      return Object.values(cart).reduce((sum, item) => sum + item.quantity, 0);
    }

    function getTotalPrice(){
      return Object.values(cart).reduce((sum, item) => sum + (item.price * item.quantity), 0);
    }

    function updateCartBadge(){
      cartCountEl.textContent = getTotalCount();
    }

    function openCart(){
      cartSidebar.classList.add("show");
      cartOverlay.classList.add("show");
    }

    function closeCartSidebar(){
      cartSidebar.classList.remove("show");
      cartOverlay.classList.remove("show");
    }

    function addToCart(product, quantity){
      if(!cart[product.id]){
        cart[product.id] = { ...product, quantity: 0 };
      }

      cart[product.id].quantity += quantity;
      saveCart();
      updateCartBadge();
      renderCart();
      showToast(quantity + "x " + product.name + " toegevoegd aan winkelwagen.");
    }

    function changeCartQty(productId, delta){
      if(!cart[productId]) return;

      cart[productId].quantity += delta;
      if(cart[productId].quantity <= 0){
        delete cart[productId];
      }

      saveCart();
      updateCartBadge();
      renderCart();
    }

    function removeFromCart(productId){
      if(cart[productId]){
        delete cart[productId];
        saveCart();
        updateCartBadge();
        renderCart();
      }
    }

    function renderCart(){
      const items = Object.values(cart);

      if(items.length === 0){
        cartItemsEl.innerHTML = '<div class="empty-state">Je winkelwagen is nog leeg.</div>';
        cartTotalEl.textContent = formatPrice(0);
        return;
      }

      cartItemsEl.innerHTML = items.map(item => `
        <div class="cart-item">
          <div class="cart-thumb">
            <img src="${item.image}" alt="${item.name}">
          </div>

          <div class="cart-info">
            <h4>${item.name}</h4>
            <p>${formatPrice(item.price)} per stuk</p>

            <div class="cart-controls">
              <button class="mini-btn" data-cart-action="minus" data-id="${item.id}">−</button>
              <span>${item.quantity}</span>
              <button class="mini-btn" data-cart-action="plus" data-id="${item.id}">+</button>
              <button class="remove-btn" data-cart-action="remove" data-id="${item.id}">Verwijder</button>
            </div>
          </div>

          <div class="cart-price">${formatPrice(item.price * item.quantity)}</div>
        </div>
      `).join("");

      cartTotalEl.textContent = formatPrice(getTotalPrice());

      cartItemsEl.querySelectorAll("[data-cart-action]").forEach(btn => {
        btn.addEventListener("click", () => {
          const action = btn.dataset.cartAction;
          const id = btn.dataset.id;

          if(action === "minus") changeCartQty(id, -1);
          if(action === "plus") changeCartQty(id, 1);
          if(action === "remove") removeFromCart(id);
        });
      });
    }

    function renderCheckoutSummary(){
      const items = Object.values(cart);

      if(items.length === 0){
        checkoutSummaryBox.innerHTML = '<div class="empty-state">Geen producten in je winkelwagen.</div>';
        return;
      }

      checkoutSummaryBox.innerHTML = `
        <div class="summary-box">
          ${items.map(item => `
            <div class="summary-line">
              <span>${item.name} x${item.quantity}</span>
              <strong>${formatPrice(item.price * item.quantity)}</strong>
            </div>
          `).join("")}

          <div class="summary-total">
            <span>Totaal</span>
            <strong>${formatPrice(getTotalPrice())}</strong>
          </div>
        </div>
      `;
    }

    function openCheckoutModal(){
      if(Object.values(cart).length === 0){
        showToast("Je winkelwagen is leeg.");
        return;
      }

      renderCheckoutSummary();
      checkoutOverlay.classList.add("show");
      checkoutModal.classList.add("show");
    }

    function closeCheckoutModal(){
      checkoutOverlay.classList.remove("show");
      checkoutModal.classList.remove("show");
    }

    function createOrder(){
      const robloxUsername = robloxUsernameInput.value.trim();
      const firstName = firstNameInput.value.trim();
      const lastName = lastNameInput.value.trim();

      if(!robloxUsername || !firstName || !lastName){
        showToast("Vul Roblox username, voornaam en achternaam in.");
        return null;
      }

      const items = Object.values(cart);
      if(items.length === 0){
        showToast("Je winkelwagen is leeg.");
        return null;
      }

      const order = {
        id: generateOrderId(),
        createdAt: new Date().toISOString(),
        status: "Waiting for payment",
        robloxUsername,
        firstName,
        lastName,
        items: items.map(item => ({
          id: item.id,
          name: item.name,
          price: item.price,
          quantity: item.quantity,
          image: item.image
        })),
        total: getTotalPrice()
      };

      const orders = loadOrders();
      orders.unshift(order);
      saveOrders(orders);
      saveLastOrderId(order.id);

      const initialChat = [
        {
          type: "system",
          text: "Order " + order.id + " aangemaakt. Gebruik deze chat voor vragen over je bestelling.",
          createdAt: new Date().toISOString()
        }
      ];
      localStorage.setItem(getChatStorageKey(order.id), JSON.stringify(initialChat));

      cart = {};
      saveCart();
      updateCartBadge();
      renderCart();

      activeOrder = order;
      renderOrder(order);
      loadChat(order.id);

      return order;
    }

    function renderOrder(order){
      if(!order){
        orderContent.innerHTML = "No order found yet. Place an order first to see it here.";
        chatLockedState.classList.remove("hidden");
        chatApp.classList.add("hidden");
        activeOrder = null;
        return;
      }

      activeOrder = order;
      const firstItem = order.items[0];

      orderContent.innerHTML = `
        <div class="order-card">
          <div class="order-top">
            <div>
              <div class="order-id">${order.id}</div>
              <div class="order-sub">Created on ${formatDate(order.createdAt)}</div>
            </div>
            <div class="status-badge status-waiting">${order.status}</div>
          </div>

          <div class="order-product">
            <div class="order-product-thumb">
              <img src="${firstItem.image}" alt="${firstItem.name}">
            </div>
            <div>
              <h4>${firstItem.name}</h4>
              <p>${firstItem.quantity}x besteld — ${formatPrice(firstItem.price)} per stuk</p>
            </div>
          </div>

          <div class="order-grid">
            <div class="order-info-box">
              <h4>Roblox username</h4>
              <p>${order.robloxUsername}</p>
            </div>

            <div class="order-info-box">
              <h4>Klantnaam</h4>
              <p>${order.firstName} ${order.lastName}</p>
            </div>

            <div class="order-info-box">
              <h4>Aantal</h4>
              <p>${firstItem.quantity}</p>
            </div>

            <div class="order-info-box">
              <h4>Totaal</h4>
              <p>${formatPrice(order.total)}</p>
            </div>
          </div>
        </div>
      `;

      chatLockedState.classList.add("hidden");
      chatApp.classList.remove("hidden");
    }

    function loadLatestOrder(){
      const lastOrderId = loadLastOrderId();
      if(!lastOrderId){
        renderOrder(null);
        return;
      }

      const orders = loadOrders();
      const order = orders.find(o => o.id === lastOrderId);

      if(order){
        renderOrder(order);
        loadChat(order.id);
      } else {
        renderOrder(null);
      }
    }

    function loadChat(orderId){
      const raw = localStorage.getItem(getChatStorageKey(orderId));
      const messages = raw ? JSON.parse(raw) : [];
      renderChatMessages(messages);
    }

    function saveChat(orderId, messages){
      localStorage.setItem(getChatStorageKey(orderId), JSON.stringify(messages));
    }

    function renderChatMessages(messages){
      if(messages.length === 0){
        chatMessages.innerHTML = '<div class="empty-state">Nog geen berichten in deze chat.</div>';
        return;
      }

      chatMessages.innerHTML = messages.map(msg => `
        <div class="chat-message ${msg.type}">
          <div>${msg.text}</div>
          <div class="chat-meta">${formatDate(msg.createdAt)}</div>
        </div>
      `).join("");

      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function sendChatMessage(){
      if(!activeOrder){
        showToast("Er is nog geen actieve order.");
        return;
      }

      const text = chatInput.value.trim();
      if(!text) return;

      const raw = localStorage.getItem(getChatStorageKey(activeOrder.id));
      const messages = raw ? JSON.parse(raw) : [];

      messages.push({
        type: "customer",
        text,
        createdAt: new Date().toISOString()
      });

      saveChat(activeOrder.id, messages);
      renderChatMessages(messages);
      chatInput.value = "";
    }

    function initProductCard(){
      const card = document.querySelector(".product-card");
      if(!card) return;

      let qty = 1;
      const qtyValue = card.querySelector(".qty-value");
      const minus = card.querySelector('[data-role="minus"]');
      const plus = card.querySelector('[data-role="plus"]');
      const addBtn = card.querySelector(".add-cart-btn");

      minus.addEventListener("click", () => {
        if(qty > 1){
          qty--;
          qtyValue.textContent = qty;
        }
      });

      plus.addEventListener("click", () => {
        qty++;
        qtyValue.textContent = qty;
      });

      addBtn.addEventListener("click", () => {
        const product = {
          id: card.dataset.id,
          name: card.dataset.name,
          price: parseFloat(card.dataset.price),
          image: card.dataset.image
        };

        addToCart(product, qty);
        openCart();
      });
    }

    cartOpenBtn.addEventListener("click", openCart);
    cartClose.addEventListener("click", closeCartSidebar);
    cartOverlay.addEventListener("click", closeCartSidebar);

    checkoutBtn.addEventListener("click", openCheckoutModal);
    closeCheckout.addEventListener("click", closeCheckoutModal);
    checkoutOverlay.addEventListener("click", closeCheckoutModal);

    confirmCheckoutBtn.addEventListener("click", () => {
      const order = createOrder();
      if(!order) return;

      closeCheckoutModal();
      showToast("Order " + order.id + " aangemaakt. Je wordt doorgestuurd naar Tikkie.");

      setTimeout(() => {
        window.open(TIKKIE_URL, "_blank");
        window.location.hash = "orders";
      }, 700);
    });

    loadLatestOrderBtn.addEventListener("click", loadLatestOrder);
    sendChatBtn.addEventListener("click", sendChatMessage);

    chatInput.addEventListener("keydown", (e) => {
      if(e.key === "Enter"){
        sendChatMessage();
      }
    });

    updateCartBadge();
    renderCart();
    initProductCard();
    loadLatestOrder();
  </script>
</body>
